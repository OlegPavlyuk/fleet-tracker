{
  "name": "@fleet-tracker/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fleet-tracker/shared": "workspace:*",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.41.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3"
  }
}
