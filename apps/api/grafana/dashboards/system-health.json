{
  "id": null,
  "uid": "fleet-system-health",
  "title": "System Health",
  "tags": ["fleet-tracker"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Event-Loop Lag (seconds)",
      "description": "> 50ms is the early-warning threshold (alert: fleet-eventloop-lag)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "event-loop lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "event-loop lag" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.05 },
                    { "color": "red", "value": 0.1 }
                  ]
                }
              },
              { "id": "custom.thresholdsStyle", "value": { "mode": "line" } }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Heap Used / Total (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "heap used"
        },
        {
          "refId": "B",
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "heap total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GC Pause Duration p99 (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(nodejs_gc_duration_seconds_bucket[1m])) by (le, kind))",
          "legendFormat": "GC p99 {{kind}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage (user + system seconds/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_user_seconds_total[1m])",
          "legendFormat": "CPU user"
        },
        {
          "refId": "B",
          "expr": "rate(process_cpu_system_seconds_total[1m])",
          "legendFormat": "CPU system"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Process Uptime",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - process_start_time_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active Handles",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_active_handles_total",
          "legendFormat": "active handles"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
