{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm format*)",
      "Bash(pnpm build*)",
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm dlx*)",
      "Bash(pnpm -r*)",
      "Bash(pnpm --filter*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(node --version*)",
      "Bash(pnpm --version*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(docker compose ps*)",
      "Bash(docker ps*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$(jq -r '.tool_input.file_path // empty')\"; case \"$FILE\" in *.ts|*.tsx|*.js|*.jsx|*.json|*.md|*.yml|*.yaml) [ -f \"$FILE\" ] && pnpm exec prettier --write \"$FILE\" >/dev/null 2>&1 || true ;; esac"
          }
        ]
      }
    ]
  }
}
