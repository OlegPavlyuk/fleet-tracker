# Database (PostGIS)
DATABASE_URL=postgres://postgres:password@localhost:5432/fleet_tracker

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m

# Server
PORT=3000
NODE_ENV=development

# Ingest WebSocket
INGEST_WS_PATH=/ws/ingest

# Realtime WebSocket
REALTIME_WS_PATH=/ws/stream

# Web
VITE_API_URL=http://localhost:3000
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Emulator (apps/emulator) — register a user via the app first, then fill these in
EMULATOR_EMAIL=your@email.com
EMULATOR_PASSWORD=yourpassword
EMULATOR_API_URL=http://localhost:3000
DRONE_COUNT=5
TICK_MS=1000
# BBOX=minLng,minLat,maxLng,maxLat  (default: Kyiv area)

# Metrics
METRICS_TOKEN=change-me-metrics-token-min16chars
